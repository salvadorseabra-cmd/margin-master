# Client-side Supabase (Vite). Copy to `.env` or `.env.local` and fill with your project values.
# Real keys are only in your Supabase dashboard; placeholders here cannot connect.
# Node scripts use the same load order as Vite (see scripts/load-env.mts).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key from Supabase → Settings → API → "anon" / "public" key.
# This codebase reads `VITE_SUPABASE_PUBLISHABLE_KEY` (not `VITE_SUPABASE_ANON_KEY`); use the same string as the anon key.

VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Server-only: service_role secret for local scripts (e.g. npm run backfill:price-history).
# Copy from Supabase → Settings → API → service_role into `.env.local` only — never commit.
SUPABASE_SERVICE_ROLE_KEY=
